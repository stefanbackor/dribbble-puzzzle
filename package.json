    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.0",
    "expo": "~55.0.0",
    "expo-asset": "~55.0.0",
    "expo-av": "~16.0.0",
    "expo-font": "~55.0.0",
    "expo-splash-screen": "~55.0.0",
    "lodash": "^4.17.21",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-redux": "^9.2.0",
